# Copiar a .env (que está en .gitignore, nunca se commitea) antes de correr
# `docker compose up`. Ver docs/ARCHITECTURE.md para cómo se usa cada variable.

# Clave HMAC-SHA256 en base64 (mínimo 32 bytes), compartida por los 3 servicios que
# manejan JWT — auth-service la usa para firmar, property-service/booking-service para validar.
# Generarla con: openssl rand -base64 32
JWT_SECRET=

# Password del usuario root de MySQL (solo para administración del contenedor —
# cada servicio se conecta con su propio usuario, creado por infra/mysql/init.sql).
MYSQL_ROOT_PASSWORD=rootpass

# --- Emails de confirmación de reserva (notification-service, ver ADR-0006) ---
# Opcionales: si quedan vacíos, la reserva se crea igual y el fallo del email solo se loguea.
# Con Gmail: SMTP_USER es tu correo y SMTP_APP_PASSWORD es un "App Password" generado en
# https://myaccount.google.com/apppasswords (requiere verificación en 2 pasos) — NUNCA tu
# contraseña real. MAIL_FROM suele ser el mismo correo que SMTP_USER.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_APP_PASSWORD=
MAIL_FROM=
